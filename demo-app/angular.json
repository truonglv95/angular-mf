{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "host": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:class": {
          "skipTests": true
        },
        "@schematics/angular:component": {
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:interceptor": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true
        },
        "@schematics/angular:resolver": {
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        }
      },
      "root": "projects/host",
      "sourceRoot": "projects/host/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-mf/esbuild:application",
          "options": {
            "browser": "projects/host/src/main.ts",
            "tsConfig": "projects/host/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/host/public"
              }
            ],
            "styles": ["projects/host/src/styles.css"],
            "mfConfig": "projects/host/mf.config.ts"
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-mf/esbuild:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "host:build:production"
            },
            "development": {
              "buildTarget": "host:build:development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "mfConfig": "projects/host/mf.config.ts"
          }
        },
        "sync-types": {
          "builder": "@angular-mf/nx:sync-types",
          "options": {}
        }
      }
    },
    "remote": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:class": {
          "skipTests": true
        },
        "@schematics/angular:component": {
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:interceptor": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true
        },
        "@schematics/angular:resolver": {
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        }
      },
      "root": "projects/remote",
      "sourceRoot": "projects/remote/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-mf/esbuild:application",
          "options": {
            "browser": "projects/remote/src/main.ts",
            "tsConfig": "projects/remote/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/remote/public"
              }
            ],
            "styles": ["projects/remote/src/styles.css"],
            "mfConfig": "projects/remote/mf.config.ts"
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-mf/esbuild:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "remote:build:production"
            },
            "development": {
              "buildTarget": "remote:build:development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "port": 4202,
            "mfConfig": "projects/remote/mf.config.ts"
          }
        }
      }
    }
  }
}
