{
  "name": "@angular-mf/core",
  "version": "0.1.0",
  "description": "Core algorithms and runtime for Angular Module Federation",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
