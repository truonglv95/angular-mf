      "default": "./dist/types/index.js"
    }
  },
  "scripts": {
    "build": "tsup"
  },
  "peerDependencies": {
    "@angular/core": ">=17",
    "esbuild": ">=0.19.0",
    "vite": ">=5.0.0"
