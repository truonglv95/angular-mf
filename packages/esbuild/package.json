{
  "name": "@angular-mf/esbuild",
  "version": "0.1.0",
  "description": "Angular CLI builders and schematics for Module Federation",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "builders.json",
    "package.json"
  ],
  "exports": {
    "./builders": {
      "types": "./dist/builders/index.d.ts",
      "default": "./dist/builders/index.js"
    },
    "./schematics": {
      "types": "./dist/schematics/index.d.ts",
      "default": "./dist/schematics/index.js"
    },
    "./package.json": "./package.json"
  },
  "builders": "builders.json",
  "schematics": "./dist/schematics/collection.json",
  "scripts": {
    "build": "tsup && mkdir -p dist/schematics/ng-add && cp src/schematics/*.json dist/schematics/ && cp src/schematics/ng-add/*.json dist/schematics/ng-add/ && cp src/builders/*.json dist/builders/"
  },
  "dependencies": {
    "@angular-mf/core": "*"
  },
  "peerDependencies": {
    "@angular-devkit/architect": ">=0.1700.0",
    "@angular-devkit/build-angular": ">=17.0.0",
    "@angular/core": ">=17",
    "esbuild": ">=0.19.0",
    "vite": ">=5.0.0"
  }
}
