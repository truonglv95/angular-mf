    "@angular/cli": ">=17.0.0",
    "@angular/core": ">=17",
    "@nx/angular": "^21.0.0",
    "@nx/devkit": "^21.0.0",
    "@types/node": "^22.0.0",
    "@types/semver": "^7.7.1",
    "esbuild": ">=0.19.0",
    "fast-check": "^3.23.2",
    "semver": "^7.8.1",
    "tsup": "^8.0.0",
    "typescript": ">=5.2.0",
